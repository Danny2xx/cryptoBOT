# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real secrets.

# --- Database (TimescaleDB / Postgres) ---
POSTGRES_USER=ctb
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ctb
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# --- Redis (event bus) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- DeFi RPC --- fill in once Epic 0 selects a chain
RPC_URL=

# --- Live trading switch --- leave false until Epic 4
LIVE_ENABLED=false
